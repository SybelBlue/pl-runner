{
  "name": "@sybelblue/prairielearn-runner",
  "version": "0.1.0",
  "description": "PrairieLearn launcher runnable through npx.",
  "homepage": "https://github.com/SybelBlue/pl-runner#readme",
  "bugs": {
    "url": "https://github.com/SybelBlue/pl-runner/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SybelBlue/pl-runner.git"
  },
  "license": "ISC",
  "author": "Serena Caraco",
  "type": "module",
  "main": "index.js",
  "bin": {
    "prairielearn-runner": "bin/pl",
    "pl": "bin/pl"
  },
  "directories": {
    "test": "test"
  },
  "files": [
    "bin",
    "dist",
    "functions",
    "completions",
    "npm-package-functional-spec.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p test/tsconfig.json",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "1.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
